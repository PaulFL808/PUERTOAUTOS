{
  "info": {
    "name": "PUERTOAUTOS API",
    "description": "Colección de pruebas para la API de anuncios de automóviles",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nombre\": \"Test Vendedor\",\n    \"email\": \"test@vendedor.com\",\n    \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@vendedor.com\",\n    \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Anuncios",
      "item": [
        {
          "name": "Obtener Todos (Público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/v1/anuncios",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "anuncios"]
            }
          }
        },
        {
          "name": "Crear Anuncio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "marca", "value": "Toyota", "type": "text" },
                { "key": "modelo", "value": "Corolla", "type": "text" },
                { "key": "año", "value": "2020", "type": "text" },
                { "key": "precio", "value": "12000000", "type": "text" },
                { "key": "kilometraje", "value": "35000", "type": "text" }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/anuncios",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "anuncios"]
            }
          }
        }
      ]
    }
  ]
}
